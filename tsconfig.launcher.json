{
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "target": "ESNext",
    "module": "commonjs",
    "declaration": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "@types/wicg-file-system-access",
      "node",
      "offscreencanvas",
    ],
    "lib": [
      "ESNext",
      "dom",
      "WebWorker"
    ],
    "listFiles": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "newLine": "LF",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "removeComments": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "strictNullChecks": false,
    "target": "ESNext",
    "types": [
      "@types/wicg-file-system-access",
      "node",
      "offscreencanvas"
    ]
  },
  "include": [
    "src/apps/launcher/**/*.ts",
    "src/apps/launcher/**/*.tsx",
    "src/apps/common/**/*.ts",
    "src/apps/common/**/*.tsx",
    "src/types",
    "src/index.d.ts"
  ],
  "exclude": ["node_modules", "src/**/*.spec.ts"]
}