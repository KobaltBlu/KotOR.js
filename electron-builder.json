{
  "asar": true,
  "directories": { "output": "release/" },
  "appId": "com.kotor.js",
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json",
    { "from": "../dist", "filter": ["**/*"] }
  ],
  "win": { "target": ["portable"] },
  "mac": {
    "category": "public.app-category.games",
    "target": ["dmg"]
  },
  "linux": { "target": ["AppImage"] }
}
