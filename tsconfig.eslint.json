{
  "extends": "./tsconfig.json",
  "compilerOptions": { "noEmit": true, "baseUrl": ".", "paths": { "@/*": ["src/*"] } },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/types/**/*.d.ts",
    "extensions/**/*.ts",
    "extensions/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", ".history"]
}
