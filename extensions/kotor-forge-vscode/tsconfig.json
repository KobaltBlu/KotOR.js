{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ES2020"
    ],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "out",
    "paths": {
      "@kotor/*": [
        "../../src/*"
      ]
    },
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "target": "ES2020"
  },
  "exclude": [
    "node_modules",
    "src/webview"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.webview.json"
    }
  ]
}
